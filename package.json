{
  "name": "windsurf-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "dev:nosourcemaps": "node --no-enable-source-maps node_modules/next/dist/bin/next dev",
    "dev:webpack:nosourcemaps": "node --no-enable-source-maps node_modules/next/dist/bin/next dev --webpack",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start -p $PORT",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "@serwist/next": "^9.5.0",
    "@tailwindcss/postcss": "^4",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "formidable": "^3.5.4",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.554.0",
    "next": "16.0.10",
    "next-intl": "^4.5.5",
    "nodemailer": "^7.0.10",
    "prisma": "^6.16.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^4.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/formidable": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
